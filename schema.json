{
  "formTitle": "Customer Request Form",
  "fields": [
    {
      "id": "fullName",
      "label": "Full Name",
      "type": "text",
      "required": true,
      "placeholder": "Enter your full name"
    },
    {
      "id": "email",
      "label": "Email Address",
      "type": "email",
      "required": true,
      "placeholder": "you@example.com"
    },
    {
      "id": "department",
      "label": "Department",
      "type": "select",
      "required": true,
      "options": ["Sales", "Support", "Engineering", "HR"]
    },
    {
      "id": "message",
      "label": "Message",
      "type": "textarea",
      "required": false,
      "placeholder": "Describe your request..."
    }
  ]
}
